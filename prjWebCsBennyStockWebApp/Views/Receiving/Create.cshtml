@{
    ViewData["Title"] = "Entrée Stock";
}

<h2>Entrée de stock - Livraison fournisseur</h2>

<div class="text-danger">
    @Html.ValidationSummary()
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <div class="mb-3">
        <label class="form-label">Restaurant</label>
        <select name="restaurantId" asp-items="ViewBag.Restaurants" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Produit</label>
        <select name="itemId" asp-items="ViewBag.Items" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Fournisseur</label>
        <select name="supplier" class="form-control" required>
            <option value="">Choisir un fournisseur</option>
            <option value="Sysco">Sysco</option>
            <option value="Costco">Costco</option>
            <option value="Autre">Autre</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Quantité reçue</label>
        <input name="quantity" type="number" step="0.1" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Facture fournisseur (PDF, JPG, PNG)</label>
        <input name="invoiceFile" type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
    </div>

    <button type="submit" class="btn btn-success">Ajouter au stock</button>
    <a asp-controller="Stock" asp-action="Index" class="btn btn-secondary">Retour</a>

</form>