@model prjWebCsBennyStockWebApp.Models.Transfer

@{
    ViewData["Title"] = "Créer un transfert";
}

<h2>Créer un transfert</h2>

<div class="text-danger">
    @Html.ValidationSummary()
</div>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Restaurant source</label>
        <select asp-for="FromRestaurantId" asp-items="ViewBag.Restaurants" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Restaurant destination</label>
        <select asp-for="ToRestaurantId" asp-items="ViewBag.Restaurants" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Produit</label>
        <select asp-for="ItemId" asp-items="ViewBag.Items" class="form-control"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Quantité</label>
        <input asp-for="Quantity" class="form-control" type="number" step="0.1" />
    </div>

    <button type="submit" class="btn btn-success">Créer le transfert</button>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</form>