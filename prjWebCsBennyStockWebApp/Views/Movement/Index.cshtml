@model List<prjWebCsBennyStockWebApp.Models.StockMovement>

<h2>Historique des mouvements de stock</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Produit</th>
            <th>Restaurant</th>
            <th>Type</th>
            <th>Quantité</th>
            <th>Date</th>
            <th>Référence</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Item?.Name</td>
                <td>@m.Restaurant?.Name</td>
                <td>@m.Type</td>
                <td>@m.Quantite</td>
                <td>@m.Date.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@m.Reference</td>
            </tr>
        }
    </tbody>
</table>