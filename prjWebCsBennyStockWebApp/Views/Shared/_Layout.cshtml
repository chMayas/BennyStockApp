<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BennyStock</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark benny-navbar shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    BennyStock
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Stock" asp-action="Index">Stocks</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Stock" asp-action="Availability">Disponibilité</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Transfer" asp-action="Index">Transferts</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Movement" asp-action="Index">Mouvements</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Receiving" asp-action="Create">Entrée Stock</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Veloce" asp-action="Import">Veloce</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Inventory" asp-action="Export">Export Excel</a>
                        </li>

                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                @Context.Session.GetString("FullName") (@Context.Session.GetString("Role"))
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link benny-logout" asp-controller="Account" asp-action="Logout">Déconnexion</a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="benny-footer mt-5">
        <div class="container">
            © 2026 - Gestion de stock Rôtisseries Benny
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>